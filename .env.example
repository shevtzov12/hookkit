# Database (Neon) — required on Vercel (file store does not persist)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Auth (Clerk) — required on Vercel for dashboard + multi-user
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# Rate limiting (Upstash) — CP-5
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) — CP-6
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=HookKit <onboarding@resend.dev>

# Turnstile — CP-5
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# App URL — set to your Vercel URL after first deploy, then redeploy
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Staging: hide landing/docs from public (dashboard + /h /f still work)
# HOOKKIT_MAINTENANCE=1

# Smoke script override
# SMOKE_BASE_URL=https://your-project.vercel.app
